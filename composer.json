{
    "require": {
        "resend/resend-php": "^1.1.0",
        "monolog/monolog": "^2.0",
        "psr/log": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "CloudCatch\\Resend\\": "classes/",
            "CloudCatch\\Resend\\Dependencies\\": "vendor-prefixed/"
        }
    },
    "config": {
        "platform": {
            "php": "8.1"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require-dev": {
        "coenjacobs/mozart": "*",
        "wp-coding-standards/wpcs": "^3.3",
        "dealerdirect/phpcodesniffer-composer-installer": "^0.7.2",
        "phpcompatibility/phpcompatibility-wp": ">=2.1.8",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "php-stubs/wp-cli-stubs": "^2.10"
    },
    "scripts": {
        "phpcs": "./vendor/bin/phpcs",
        "phpcbf": "./vendor/bin/phpcbf",
        "phpstan": "./vendor/bin/phpstan analyze",
        "mozart": "./vendor/bin/mozart compose",
        "fix-namespaces": "php bin/fix-mozart-namespaces.php",
        "post-install-cmd": [
            "@mozart",
            "@fix-namespaces",
            "composer dump-autoload"
        ],
        "post-update-cmd": [
            "@mozart",
            "@fix-namespaces",
            "composer dump-autoload"
        ],
        "test": [
            "@phpcs",
            "@phpstan"
        ],
        "zip": "bash bin/build-zip.sh"
    },
    "extra": {
        "mozart": {
            "dep_namespace": "CloudCatch\\Resend\\Dependencies\\",
            "dep_directory": "/vendor-prefixed/",
            "classmap_directory": "/vendor-prefixed/composer/",
            "classmap_prefix": "CloudCatch_Resend_",
            "packages": [
                "resend/resend-php",
                "monolog/monolog",
                "psr/log"
            ],
            "delete_vendor_directories": false
        }
    }
}